          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/api/audit/logs"
          }
        },
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/notifications?userId={{clientId}}"
          }
        }
      ]

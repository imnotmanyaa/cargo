    {
      "name": "Pilot Flow Test Order",
      "item": [
        {
          "name": "01 Create Shipment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('shipmentId', data.id);",
                  "  if (data.shipment_number) pm.collectionVariables.set('trackingCode', data.shipment_number);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_name\": \"Client User\",\n  \"client_email\": \"{{clientEmail}}\",\n  \"from_station\": \"{{originStation}}\",\n  \"to_station\": \"{{destinationStation}}\",\n  \"departure_date\": \"2026-03-15T10:00:00Z\",\n  \"weight\": \"20\",\n  \"dimensions\": \"30x30x40\",\n  \"description\": \"Cargo box\",\n  \"value\": \"50000\",\n  \"cost\": 7000,\n  \"quantity_places\": 1,\n  \"receiver_name\": \"{{receiverName}}\",\n  \"receiver_phone\": \"{{receiverPhone}}\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments"
          }
        },
        {
          "name": "02 Calculate Tariff",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/calculate-tariff"
          }
        },
        {
          "name": "03 Send To Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/send-to-payment"
          }
        },
        {
          "name": "04 Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('paymentId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipment_id\": \"{{shipmentId}}\",\n  \"amount\": 7000,\n  \"payment_method\": \"POS\",\n  \"pos_terminal_reference\": \"POS-001\"\n}"
            },
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "05 Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}/confirm"
          }
        },
        {
          "name": "06 Generate QR",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.shipment && data.shipment.tracking_code) pm.collectionVariables.set('trackingCode', data.shipment.tracking_code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorToken}}" }
            ],
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/generate-qr"
          }
        },
        {
          "name": "07 Load Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{loadingToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_station\": \"{{originStation}}\",\n  \"transport_unit_id\": \"wagon-12\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/load"
          }
        },
        {
          "name": "08 Dispatch Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{loadingToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_station\": \"{{originStation}}\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/dispatch"
          }
        },
        {
          "name": "09 Mark Transit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{transitToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_station\": \"{{transitStation}}\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/mark-transit"
          }
        },
        {
          "name": "10 Arrive Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{receiverToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_station\": \"{{destinationStation}}\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/arrive"
          }
        },
        {
          "name": "11 Ready For Issue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{receiverToken}}" }
            ],
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/ready-for-issue"
          }
        },
        {
          "name": "12 Issue Scan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{issueToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipment_id\": \"{{shipmentId}}\",\n  \"event_type\": \"ISSUE_SCAN\",\n  \"station_id\": \"{{destinationStation}}\",\n  \"comment\": \"receiver verified at issue desk\"\n}"
            },
            "url": "{{baseUrl}}/api/scan"
          }
        },
        {
          "name": "13 Issue Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{issueToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver_name\": \"{{receiverName}}\",\n  \"receiver_phone\": \"{{receiverPhone}}\"\n}"
            },
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/issue"
          }
        },
        {
          "name": "14 Close Shipment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{issueToken}}" }
            ],
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/close"
          }
        }
      ]
    },
    {
      "name": "Tracking And Reports",
      "item": [
        {
          "name": "Track Shipment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/track/{{trackingCode}}"
